{
  "name": "managed-service-skeleton-api",
  "version": "1.0.0",
  "description": "Small TypeScript/Node.js lab simulating a managed service backend skeleton.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
